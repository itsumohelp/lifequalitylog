// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model AppLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  logLevel  String   @map("log_level") @db.VarChar(10)
  message   String   @db.Text
  context   Json?
  @@map("app_logs")
  @@index([createdAt])
  @@index([logLevel])
}

model Todo {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  title  String   @db.Text
  status Int @db.Integer
  userid String @db.Text
  cost Int @db.Integer
  name String @db.Text
  updateAt DateTime? @map("update_at") @db.Timestamptz
  record Record[]
  @@index([createdAt])
}

model Record {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  todoid  String   @db.Uuid
  status Int @db.Integer
  updateAt DateTime? @map("update_at") @db.Timestamptz
  ended DateTime? @db.Timestamptz
  todo Todo @relation(fields: [todoid], references: [id], onDelete: Cascade)
  @@index([todoid])
  @@index([createdAt])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  displayName   String?   @map("display_name")
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  autoTagEnabled Boolean   @default(false) @map("auto_tag_enabled")
  accounts      Account[]
  sessions      Session[]
  circleMembers CircleMember[]
  snapshots     Snapshot[]
  circleSnapshots CircleSnapshot[]
  expenses      Expense[]
  incomes       Income[]
  reactions     Reaction[]
  balanceTransactions BalanceTransaction[]
  @@map("users")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime
  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Circle {
  id             String          @id @default(cuid())
  name           String
  description    String?
  walletName     String?
  currency       String          @default("JPY")
  currentBalance Int             @default(0) // キャッシュされた現在残高
  isPublic       Boolean         @default(false) // フィード公開設定
  allowNewMembers Boolean        @default(true) // 招待リンクでの新規参加を許可
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  members        CircleMember[]
  snapshots      Snapshot[]
  circleSnapshots CircleSnapshot[]
  expenses       Expense[]
  incomes        Income[]
  monthlySnapshots MonthlySnapshot[]
  balanceTransactions BalanceTransaction[]
}

model CircleMember {
  id        String     @id @default(cuid())
  circleId  String
  userId    String
  role      CircleRole
  joinedAt  DateTime   @default(now())
  circle    Circle     @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id])
  @@unique([circleId, userId])
}

model Snapshot {
  id               String   @id @default(cuid())
  circleId         String
  circle           Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  amount           Int
  memo             String?
  recordedAt       DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  @@index([circleId, recordedAt])
}

enum CircleRole {
  ADMIN
  EDITOR
  VIEWER
}

model CircleSnapshot {
  id        String   @id @default(cuid())
  circleId  String
  circle    Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  userId String
  user   User     @relation(fields: [userId], references: [id])
  amount    Int
  note      String?
  snapshotDate DateTime
  createdAt    DateTime @default(now())
　signature     String
  signatureAlgo String
  signatureAt   DateTime
  isSignatureVerified Boolean @default(true)
  diffFromPrev Int?
  @@index([circleId, createdAt])
  @@index([userId])
}

// 月次集計スナップショット（YYYYMM形式）
model MonthlySnapshot {
  id          String   @id @default(cuid())
  circleId    String
  circle      Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  yearMonth   String   // YYYYMM形式（例: "202601"）
  totalExpense Int     @default(0) // 当月の支出合計
  expenseCount Int     @default(0) // 当月の支出件数
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@unique([circleId, yearMonth])
  @@index([yearMonth])
}

// 支出カテゴリ
enum ExpenseCategory {
  FOOD        // 食費
  DAILY       // 日用品
  TRANSPORT   // 交通費
  ENTERTAINMENT // 娯楽
  UTILITY     // 光熱費
  MEDICAL     // 医療
  OTHER       // その他
}

// 支出記録
model Expense {
  id          String          @id @default(cuid())
  circleId    String
  circle      Circle          @relation(fields: [circleId], references: [id], onDelete: Cascade)
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  amount      Int             // 金額
  description String          // 入力された説明（例：「コンビニで500円」）
  place       String?         // パースした場所
  category    ExpenseCategory @default(OTHER)
  tags        String[]        // 手動タグ（例：["コンビニ"]）
  autoTags    String[]        // 自動提案タグ（ルールベース）
  expenseDate DateTime        @default(now()) // 支出日時
  createdAt   DateTime        @default(now())
  @@index([circleId, expenseDate])
  @@index([userId])
}

// 収入カテゴリ
enum IncomeCategory {
  SALARY      // 給与
  BONUS       // ボーナス
  INVESTMENT  // 投資
  TRANSFER    // 振込
  OTHER       // その他
}

// 収入記録
model Income {
  id          String          @id @default(cuid())
  circleId    String
  circle      Circle          @relation(fields: [circleId], references: [id], onDelete: Cascade)
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  amount      Int             // 金額
  description String          // 入力された説明（例：「給与 250000円」）
  source      String?         // 収入元（例：「会社」）
  category    IncomeCategory  @default(OTHER)
  tags        String[]        // タグ
  autoTags    String[]        // 自動提案タグ（ルールベース）
  incomeDate  DateTime        @default(now()) // 収入日時
  createdAt   DateTime        @default(now())
  @@index([circleId, incomeDate])
  @@index([userId])
}

// 残高変更種別
enum BalanceTransactionType {
  EXPENSE     // 支出
  INCOME      // 収入
  SNAPSHOT    // 残高更新
}

// 残高変更トランザクションログ
model BalanceTransaction {
  id              String                @id @default(cuid())
  circleId        String
  circle          Circle                @relation(fields: [circleId], references: [id], onDelete: Cascade)
  userId          String
  user            User                  @relation(fields: [userId], references: [id])
  type            BalanceTransactionType
  isDelete        Boolean               @default(false)
  amount          Int
  balanceBefore   Int
  balanceAfter    Int
  createdAt       DateTime              @default(now())
  @@index([circleId, createdAt])
  @@index([userId])
}

// リアクションタイプ
enum ReactionType {
  CHECK   // 緑色のチェックマーク
  GOOD    // 👍
  BAD     // 👎
  DOGEZA  // 🙇
}

// リアクション記録
model Reaction {
  id          String       @id @default(cuid())
  userId      String       @map("user_id")
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetType  String       @map("target_type") // "expense", "income", "snapshot"
  targetId    String       @map("target_id")
  type        ReactionType
  createdAt   DateTime     @default(now()) @map("created_at")
  @@unique([userId, targetType, targetId, type]) // 同じユーザーが同じ投稿に同じリアクションは1回まで
  @@index([targetType, targetId]) // 投稿ごとのリアクション取得用（高速化）
  @@map("reactions")
}

model IosAuthToken {
  pollId    String   @id
  token     String   @db.Text
  expiresAt DateTime
  @@map("ios_auth_tokens")
}

// AIインサイト（サークルごとの日次フィードバック）
model UserInsight {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  circleId    String?  @map("circle_id")
  insight     String   @db.Text
  generatedAt DateTime @default(now()) @map("generated_at")
  @@index([userId, circleId, generatedAt])
  @@map("user_insights")
}

// 運営からのお知らせ
model Notice {
  id        String   @id @default(cuid())
  title     String   @db.Text
  body      String?  @db.Text
  link      String?  @db.Text // タップ時のリンクURL（任意）
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz
  @@index([isActive, createdAt])
  @@map("notices")
}
